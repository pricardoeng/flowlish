generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String              @id @default(cuid())
  name             String?
  email            String              @unique
  goal             String?
  nativeLanguage   String              @default("Portuguese")
  currentLevel     String              @default("A1")
  createdAt        DateTime            @default(now())
  password         String?
  certificates     Certificate[]
  learningSessions LearningSession[]
  purchases        Purchase[]
  testSessions     TestSession[]
  progress         UserChunkProgress[]
  wordProgress     UserWordProgress[]
  speechQueues     SpeechQueue[]
  interests        String[]            @default([])
  unlockedPacks    String[]            @default([])
  userBadges       UserBadge[]
}

model Chunk {
  id                    String              @id @default(cuid())
  englishText           String
  portugueseTranslation String
  cefrLevel             String
  context               String?
  theme                 String?
  pack                  String?
  variant               String              @default("US")
  tags                  String?
  audioUrl              String?
  createdAt             DateTime            @default(now())
  imageUrl              String?
  isFree                Boolean             @default(false)
  userProgress          UserChunkProgress[]
}

model UserChunkProgress {
  id             String    @id @default(cuid())
  userId         String
  chunkId        String
  status         String    @default("new")
  masteryScore   Int       @default(0)
  isFavorite     Boolean   @default(false)
  lastReviewedAt DateTime?
  nextReviewAt   DateTime?
  chunk          Chunk     @relation(fields: [chunkId], references: [id])
  user           User      @relation(fields: [userId], references: [id])

  @@unique([userId, chunkId])
}

model Word {
  id                    String             @id @default(cuid())
  englishWord           String
  portugueseTranslation String
  cefrLevel             String
  theme                 String?
  imageUrl              String?
  audioUrl              String?
  createdAt             DateTime           @default(now())
  userProgress          UserWordProgress[]
}

model UserWordProgress {
  id            String   @id @default(cuid())
  userId        String
  wordId        String
  status        String   @default("new")
  masteryScore  Int      @default(0)
  lastReviewed  DateTime @default(now())
  timesReviewed Int      @default(0)
  isFavorite    Boolean  @default(false)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  word          Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@unique([userId, wordId])
}

model LearningSession {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime @default(now())
  sessionType String
  score       Int
  user        User     @relation(fields: [userId], references: [id])
}

model SpeechQueue {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  status    String   @default("waiting") // 'waiting', 'matched', 'completed'
  roomId    String?  
  targetId  String?  
  createdAt DateTime @default(now())
}

model TestSession {
  id        String   @id @default(cuid())
  userId    String
  config    String
  score     Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Badge {
  id          String   @id @default(cuid())
  name        String
  description String
  category    String   // 'milestone', 'skill', 'streak', 'rare'
  icon        String
  targetType  String   // 'mastered_chunks', 'xp', 'streak_days', 'pack_complete'
  targetValue Int
  tier        String   @default("BRONZE") // BRONZE, SILVER, GOLD, DIAMOND
  rarity      Float?   // Cache of percent users who have this
  nextTierId  String?
  userBadges  UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  earnedAt  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  badge     Badge    @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
}

model Certificate {
  id       String   @id @default(cuid())
  userId   String
  level    String
  issuedAt DateTime @default(now())
  shareUrl String?
  user     User     @relation(fields: [userId], references: [id])
}

model Purchase {
  id         String   @id @default(cuid())
  userId     String
  planType   String
  levelScope String?
  packId     String?
  status     String   @default("active")
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}
