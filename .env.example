# -----------------------------------------------------------------------------
# FLOWLISH - PRODUCTION ENVIRONMENT TEMPLATE
# Copy this file to .env or set these variables in your hosting provider (Vercel/etc)
# -----------------------------------------------------------------------------

# DATABASE
# For SQLite (Dev): "file:./dev.db"
# For Postgres (Prod): "postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
DATABASE_URL=""

# NEXT AUTH
# Final domain URL (e.g., https://flowlish.com)
NEXTAUTH_URL=""
# Generate a secret: 'openssl rand -base64 32'
NEXTAUTH_SECRET=""

# DAILY.CO (Speakeasy Video Rooms)
# Get these from your Daily.co dashboard
NEXT_PUBLIC_DAILY_DOMAIN=""
DAILY_API_KEY=""

# STRIPE (Optional - for future payments)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# NEXT.JS CORE
NODE_ENV="production"
